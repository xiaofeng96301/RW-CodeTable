[
  {
    "code": "name:",
    "code_translation": "名称",
    "intro": "Value Type: string\n描述: 定义单位的原始名称，游戏用它作为唯一标识（不在游戏中显示）。",
    "example": "name: customTank1",
    "version": ""
  },
  {
    "code": "mass:",
    "code_translation": "质量",
    "intro": "Value Type: int\n描述: 单位的“重量”，影响与其他单位的碰撞，值越大越难被推动。",
    "example": "mass: 3000",
    "version": ""
  },
  {
    "code": "radius:",
    "code_translation": "半径",
    "intro": "Value Type: int\n描述: 单位周围的圆形区域，用于鼠标点击/触摸选中。",
    "example": "radius: 20",
    "version": ""
  },
  {
    "code": "price:",
    "code_translation": "价格",
    "intro": "Value Type: int / price\n描述: 单位从建造器/建筑中的花费。若不指定资源类型，默认为 credits。",
    "example": "price: 500, gold=5, stone=10",
    "version": ""
  },
  {
    "code": "class:",
    "code_translation": "类",
    "intro": "Value Type: string\n描述: 预留未来使用，默认必须为 CustomUnitMetadata。",
    "example": "class: CustomUnitMetadata",
    "version": ""
  },
  {
    "code": "maxHp:",
    "code_translation": "最大生命值",
    "intro": "Value Type: int\n描述: 单位的最大生命值（生成时即为此值）。",
    "example": "maxHp: 200",
    "version": ""
  },
  {
    "code": "techLevel:",
    "code_translation": "技术等级",
    "intro": "Value Type: int\n描述: 定义单位的技术等级，共3级，不同等级在界面中显示不同颜色。",
    "example": "techLevel: 1",
    "version": ""
  },
  {
    "code": "buildSpeed:",
    "code_translation": "建造速度",
    "intro": "Value Type: float / s\n描述: 建造该单位所需时间（可能与建造器速度相乘）。",
    "example": "buildSpeed: 3s",
    "version": ""
  },
  {
    "code": "altNames:",
    "code_translation": "备用名称",
    "intro": "Value Type: string(s)\n描述: 逗号分隔的名称列表，优先级低于 name，用于多可选模组。",
    "example": "altNames: custTank1, customTank1, cTank1",
    "version": ""
  },
  {
    "code": "strictLevel:",
    "code_translation": "严格等级",
    "intro": "Value Type: float\n描述: 默认为0。1 = 键重复时报错。添加到根目录的 all-units.template 可应用于所有单位。",
    "example": "strictLevel: 1",
    "version": "1.13.3"
  },
  {
    "code": "isBio:",
    "code_translation": "是否为生物",
    "intro": "Value Type: bool\n描述: 选择单位是否为生物，影响声音和飞溅效果（除非 hideScorchMark:true）。",
    "example": "isBio: true",
    "version": ""
  },
  {
    "code": "isBug:",
    "code_translation": "是否为虫子",
    "intro": "Value Type: bool\n描述: 更改一些死亡默认行为，以及沙盒中的排序。",
    "example": "isBug: false",
    "version": ""
  },
  {
    "code": "isBuilder:",
    "code_translation": "是否为建造者",
    "intro": "Value Type: bool\n描述: 如果此单位可以放置建筑，通常需要设为 true。默认值为 [ai]useAsBuilder。",
    "example": "isBuilder: true",
    "version": "1.13"
  },
  {
    "code": "streamingCost:",
    "code_translation": "流式花费",
    "intro": "Value Type: price\n描述: 类似于 price，但在单位排队或建造期间按时间支付。建造过程中若资源耗尽，建造或队列会暂停。",
    "example": "streamingCost: gem=420",
    "version": "1.15"
  },
  {
    "code": "switchPriceWithStreamingCost:",
    "code_translation": "流式花费互换价格",
    "intro": "Value Type: bool\n描述: 快捷方式：将 streamingCost 设为 price 值并清空 price，添加到 all-units.template 可快速将模组切换为流式资源。",
    "example": "switchPriceWithStreamingCost: true",
    "version": "1.15"
  },
  {
    "code": "selfRegenRate:",
    "code_translation": "自我修复速率",
    "intro": "Value Type: float\n描述: 被动自我修复速率。",
    "example": "selfRegenRate: 0.01",
    "version": ""
  },
  {
    "code": "maxShield:",
    "code_translation": "最大护盾",
    "intro": "Value Type: int\n描述: 单位最大护盾值。如果 startShieldAtZero:true，初始护盾可为0。",
    "example": "maxShield: 500",
    "version": ""
  },
  {
    "code": "startShieldAtZero:",
    "code_translation": "护盾初始为零",
    "intro": "Value Type: bool\n描述: 若为 true，单位生成时护盾值为0。",
    "example": "startShieldAtZero: true",
    "version": ""
  },
  {
    "code": "shieldRegen:",
    "code_translation": "护盾恢复速率",
    "intro": "Value Type: float\n描述: 被动护盾恢复速率。",
    "example": "shieldRegen: 0.15",
    "version": ""
  },
  {
    "code": "energyMax:",
    "code_translation": "最大能量",
    "intro": "Value Type: float\n描述: 默认为0。可用作炮塔弹药、激光防御和行动的能量。",
    "example": "energyMax: 1",
    "version": ""
  },
  {
    "code": "energyRegen:",
    "code_translation": "能量恢复速率",
    "intro": "Value Type: float\n描述: 被动能量恢复速率。",
    "example": "energyRegen: 0.001",
    "version": ""
  },
  {
    "code": "energyStartingPercentage:",
    "code_translation": "初始能量百分比",
    "intro": "Value Type: float\n描述: 单位首次建成时已充能能量的百分比。",
    "example": "energyStartingPercentage: 0.5",
    "version": ""
  },
  {
    "code": "energyNeedsToRechargeToFull:",
    "code_translation": "能量需充满才能使用",
    "intro": "Value Type: float\n描述: 若为 true，能量归零后需完全充满才能再次使用武器。",
    "example": "energyNeedsToRechargeToFull: true",
    "version": ""
  },
  {
    "code": "energyRegenWhenRecharging:",
    "code_translation": "充电时的恢复速率",
    "intro": "Value Type: float\n描述: 重新充电时的恢复速率。",
    "example": "",
    "version": ""
  },
  {
    "code": "armour:",
    "code_translation": "护甲",
    "intro": "Value Type: int\n描述: 每次命中减免的伤害（目前未在任何原版单位中使用）。",
    "example": "armour: 6",
    "version": "1.13"
  },
  {
    "code": "armourMinDamageToKeep:",
    "code_translation": "护甲保留的最小伤害",
    "intro": "Value Type: int\n描述: 受击时保留的最小伤害，默认为1。",
    "example": "armourMinDamageToKeep: 2",
    "version": "1.13"
  },
  {
    "code": "borrowResourcesWhileAlive:",
    "code_translation": "存活时借用的资源",
    "intro": "Value Type: price\n描述: 创建时获取这些资源，移除或销毁时返还。",
    "example": "borrowResourcesWhileAlive: gold=10",
    "version": "1.13.3"
  },
  {
    "code": "borrowResourcesWhileBuilt:",
    "code_translation": "建成后借用的资源",
    "intro": "Value Type: price\n描述: 类似 borrowResourcesWhileAlive，但直到建成后才生效。主要用于建筑（如房屋）添加负资源来影响单位上限等。",
