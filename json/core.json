  },
  {
    "code": "generation_credits:",
    "code_translation": "产生的 credits",
    "intro": "Value Type: int\n描述: 单位产生的收入（仅 credits）。",
    "example": "generation_credits: 2",
    "version": ""
  },
  {
    "code": "generation_delay:",
    "code_translation": "资源产生延迟",
